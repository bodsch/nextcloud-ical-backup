# --- Python bytecode / caches ------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Virtual environments ----------------------------------------------------
.venv/
venv/
env/
.python-version

# --- Packaging / build artifacts ---------------------------------------------
build/
dist/
*.egg-info/
*.egg
wheels/
.eggs/

# --- uv ----------------------------------------------------------------------
# Keep uv.lock under version control; ignore uv's local cache only.
.uv/

# --- Test / type-check / lint caches -----------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# --- Backup output -----------------------------------------------------------
# Default destination of `nextcloud-ical-backup backup --backup-root ./backup`.
# Never commit exported calendar/contact data (it is personal data).
/backup/
*.ics
*.vcf

# --- Local secrets / config --------------------------------------------------
# A real Nextcloud config.php contains database credentials; never commit it.
config.php
*.local.toml
.env
.env.*

# --- Go ----------------------------------------------------------------------
# Compiled binary produced by `go build` in go/.
/go/nextcloud-ical-backup
*.test
*.out
# Keep go.mod/go.sum under version control; vendor/ is optional.
/go/vendor/

# --- Editor / OS -------------------------------------------------------------
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db
